{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "palette": {
    "bg": "#1A1B27",
    "bg-dark": "#13141E",
    "bg-mid": "#1E2036",
    "bg-light": "#24283B",
    "fg": "#C0CAF5",
    "fg-dim": "#565F89",
    "black": "#2A2734",
    "red": "#F7768E",
    "green": "#9ECE6A",
    "yellow": "#E0AF68",
    "blue": "#7AA2F7",
    "magenta": "#BB9AF7",
    "cyan": "#7DCFFF",
    "white": "#A9B1D6",
    "orange": "#E69F51",
    "teal": "#00BCDB",
    "purple": "#9B84EE"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:fg-dim",
          "template": "╭─"
        },
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:bg",
          "background": "p:fg",
          "template": " {{ if .WSL }}WSL{{ end }}{{.Icon}} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:bg",
          "background": "p:blue",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:fg",
          "background": "p:bg-light",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#565F89{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#DB4B6B{{ end }}",
            "{{ if gt .Ahead 0 }}#414868{{ end }}",
            "{{ if gt .Behind 0 }}#414868{{ end }}"
          ],
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "properties": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:white",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "background": "p:bg",
          "template": "{{ if gt .Code 0 }}\uf00d {{ reason .Code }}{{ else }}\uf00c{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:yellow",
          "background": "p:bg",
          "template": " \uf252 {{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:green",
          "background": "p:bg",
          "template": " \ue718 {{ .Full }} ",
          "properties": {
            "fetch_package_manager": false
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:cyan",
          "background": "p:bg",
          "template": " \ue235 {{ if .Venv }}{{ .Venv }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:teal",
          "background": "p:bg",
          "template": " \ue627 {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:orange",
          "background": "p:bg",
          "template": " \ue7a8 {{ .Full }} "
        },
        {
          "type": "kubectl",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:purple",
          "background": "p:bg",
          "template": " \ufd31 {{ .Context }}{{ if .Namespace }} :: {{ .Namespace }}{{ end }} "
        },
        {
          "type": "aws",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:yellow",
          "background": "p:bg",
          "template": " \ue7ad {{ .Profile }}{{ if .Region }} @ {{ .Region }}{{ end }} "
        },
        {
          "type": "time",
          "style": "powerline",
          "powerline_symbol": "\ue0b6",
          "invert_powerline": true,
          "foreground": "p:fg-dim",
          "background": "p:bg",
          "template": " \uf017 {{ .CurrentDate | date \"15:04\" }} ",
          "properties": {
            "time_format": "15:04"
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:fg-dim",
          "template": "─╮"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:fg-dim",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "╰─"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:cyan",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "❯ "
        }
      ]
    }
  ],
  "secondary_prompt": {
    "foreground": "p:fg-dim",
    "template": "╰─❯ "
  },
  "transient_prompt": {
    "foreground": "p:cyan",
    "foreground_templates": [
      "{{ if gt .Code 0 }}p:red{{ end }}"
    ],
    "template": "❯ "
  }
}
